# Vite build-time config (copy to web/.env.local for local dev).
# OIDC authority (Keycloak dev realm) and the public SPA client.
VITE_OIDC_AUTHORITY=http://localhost:8080/realms/usg-itsm
VITE_OIDC_CLIENT_ID=usg-itsm-web
# API base path. Same-origin /api in dev (proxied by Vite to the gateway).
VITE_API_BASE=/api
