# Copy to .env and adjust for local development. NEVER commit a real .env.
# These values line up with compose/docker-compose.yml and the imported
# Keycloak realm.

# --- Common ---
ENVIRONMENT=dev
LOG_LEVEL=info
SHUTDOWN_TIMEOUT=15s

# --- Gateway ---
# Leave TLS_CERT_FILE/KEY empty in dev to use an in-memory self-signed cert.
ADDR=:8443
TLS_CERT_FILE=
TLS_KEY_FILE=

# --- OIDC (Keycloak dev realm) ---
# Issuer must be reachable from where the service runs. From the host use
# localhost; from inside compose use http://keycloak:8080/realms/usg-itsm.
OIDC_ISSUER=http://localhost:8080/realms/usg-itsm
OIDC_AUDIENCE=usg-itsm-web
OIDC_ROLES_CLAIM=roles

# --- Backing services (host ports from the compose stack) ---
DATABASE_URL=postgres://itsm:itsm@localhost:5432/itsm?sslmode=disable
NATS_URL=nats://localhost:4222
OLRIC_ADDR=localhost:3320
S3_ENDPOINT=http://localhost:8333
S3_BUCKET=itsm-attachments
S3_ACCESS_KEY=
S3_SECRET_KEY=
