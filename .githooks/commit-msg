#!/bin/sh
# Conventional Commits validator. Installed via `make hooks`
# (git config core.hooksPath .githooks).
#
# Rejects commit messages that do not match Conventional Commits 1.0.0.

msg_file="$1"
# First non-comment, non-empty line is the subject.
subject="$(grep -v '^#' "$msg_file" | sed '/^[[:space:]]*$/d' | head -n1)"

# Allow merge/revert commits generated by git.
case "$subject" in
  "Merge "*|"Revert "*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._-]+\))?(!)?: .+'

if printf '%s' "$subject" | grep -Eq "$pattern"; then
  # Enforce a reasonable subject length (<= 72 chars).
  if [ "${#subject}" -gt 72 ]; then
    echo "✗ Commit subject exceeds 72 characters (${#subject})." >&2
    echo "  $subject" >&2
    exit 1
  fi
  exit 0
fi

cat >&2 <<'EOF'
✗ Commit message does not follow Conventional Commits.

  Format:  <type>(<scope>): <description>
  Types:   feat fix docs style refactor perf test build ci chore revert
  Example: feat(ticketing): add work-item state machine

See CONTRIBUTING.md for the full specification.
EOF
exit 1
