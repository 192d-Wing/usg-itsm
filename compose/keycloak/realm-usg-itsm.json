{
  "realm": "usg-itsm",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "requester", "description": "Submit and track own tickets" },
      { "name": "agent", "description": "Work and resolve tickets" },
      { "name": "approver", "description": "Approve service requests" },
      { "name": "admin", "description": "Administer the platform" }
    ]
  },
  "clients": [
    {
      "clientId": "usg-itsm-web",
      "name": "USG-ITSM Web SPA",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5173/*", "https://localhost:8443/*"],
      "webOrigins": ["http://localhost:5173", "https://localhost:8443"],
      "protocol": "openid-connect",
      "attributes": { "post.logout.redirect.uris": "+" },
      "protocolMappers": [
        {
          "name": "realm-roles-to-roles-claim",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "audience-self",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "usg-itsm-web",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "agent1",
      "enabled": true,
      "email": "agent1@dev.local",
      "firstName": "Agent",
      "lastName": "One",
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "agent1", "temporary": false }
      ],
      "realmRoles": ["agent"]
    },
    {
      "username": "requester1",
      "enabled": true,
      "email": "requester1@dev.local",
      "firstName": "Requester",
      "lastName": "One",
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "requester1", "temporary": false }
      ],
      "realmRoles": ["requester"]
    }
  ]
}
